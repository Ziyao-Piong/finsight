# Copy this file to `.env` and fill in the keys for the provider you want to use.
# `.env` is gitignored — never commit real keys.
#
# You only need keys for the provider selected by LLM_PROVIDER below.

# Which provider the whole app uses: "anthropic" or "openai".
# This single switch flips both the chat model and the embeddings.
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) -------------------------------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default chat model for this project (good tool-use, cheaper than Opus).
# You can swap to claude-opus-4-8 here — but see the LLM_TEMPERATURE note below.
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# --- OpenAI -------------------------------------------------------------------
# Get a key at https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Voyage AI (embeddings for the Anthropic path) ----------------------------
# Anthropic has no first-party embeddings model; Voyage is the recommended pair.
# Only needed once you start embedding text (Phase 1+), not for the Phase 0 chat test.
# Get a key at https://www.voyageai.com/
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3

# --- Generation knobs ---------------------------------------------------------
# Max tokens the model may generate per response.
LLM_MAX_TOKENS=1024
# Sampling temperature. LEFT UNSET ON PURPOSE — newer Claude models
# (Opus 4.7 / 4.8 / Fable 5) REJECT a temperature parameter with a 400 error.
# Leaving it unset keeps provider-swapping safe. Uncomment only if your chosen
# model supports it (e.g. gpt-4o-mini, claude-sonnet-4-6).
# LLM_TEMPERATURE=0

# --- Storage paths (used from Phase 1 onward) ---------------------------------
CHROMA_DIR=.chroma
