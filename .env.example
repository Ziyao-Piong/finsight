# Copy this file to `.env` and fill in the keys for the provider you want to use.
# `.env` is gitignored — never commit real keys.
#
# You only need keys for the provider selected by LLM_PROVIDER below.

# Which provider the whole app uses. This single switch flips both the chat
# model and the embeddings.
#   anthropic / openai -> frontier (hosted, paid)
#   groq               -> hosted open-source, free tier (no local hardware needed)
#   ollama             -> offline open-source, runs locally
LLM_PROVIDER=

# --- Anthropic (Claude) -------------------------------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default chat model for this project (good tool-use, cheaper than Opus).
# You can swap to claude-opus-4-8 here — but see the LLM_TEMPERATURE note below.
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# --- OpenAI -------------------------------------------------------------------
# Get a key at https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Voyage AI (embeddings for the Anthropic path) ----------------------------
# Anthropic has no first-party embeddings model; Voyage is the recommended pair.
# Only needed once you start embedding text (Phase 1+), not for the Phase 0 chat test.
# Get a key at https://www.voyageai.com/
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3

# --- Groq (hosted open-source chat) -------------------------------------------
# Free tier, rate-limited but plenty for dev/eval. Get a key at
# https://console.groq.com/keys . Groq's API is OpenAI-compatible, so the app
# reuses the OpenAI integration pointed at the Groq base_url. Groq has no
# embeddings API — the Groq path embeds locally with HF_EMBED_MODEL below.
GROQ_API_KEY=
# Groq rotates model ids; check https://console.groq.com/docs/models if you 400.
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Ollama (offline open-source, runs locally) -------------------------------
# No API key needed. Install Ollama (https://ollama.com), start it, then pull
# the models:  ollama pull qwen2.5:7b && ollama pull nomic-embed-text
# qwen2.5:7b has strong tool-use for its size and fits an M2 Pro; use
# qwen2.5:14b on a 32 GB machine for more reliable multi-step agent behavior.
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# --- HuggingFace embeddings (local; used by the Groq path) --------------------
# Sentence-transformers model that runs on-device (Metal on Apple Silicon),
# free and no key required. ~130 MB download on first use.
HF_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Generation knobs ---------------------------------------------------------
# Max tokens the model may generate per response.
LLM_MAX_TOKENS=1024
# Sampling temperature. LEFT UNSET ON PURPOSE — newer Claude models
# (Opus 4.7 / 4.8 / Fable 5) REJECT a temperature parameter with a 400 error.
# Leaving it unset keeps provider-swapping safe. Uncomment only if your chosen
# model supports it (e.g. gpt-4o-mini, claude-sonnet-4-6).
# LLM_TEMPERATURE=0

# --- Storage paths (used from Phase 1 onward) ---------------------------------
CHROMA_DIR=.chroma
